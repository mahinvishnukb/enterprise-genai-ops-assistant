# LLM provider: "mock" works offline with zero API keys (used in CI & tests).
# Switch to "openai" or "anthropic" once you have a key to demo it live.
LLM_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=postgresql://genai_user:genai_pass@localhost:5432/genai_ops
# Tests/local dev without Docker fall back to SQLite automatically.

CHROMA_PERSIST_DIR=./chroma_store
